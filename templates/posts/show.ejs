<%- include("../partials/_header") %>

<main class="container my-4">

    <div class="mb-3 d-flex justify-content-between align-items-center">
        <a href="/posts" class="btn btn-sm btn-outline-secondary">← Return</a>

        <% if (req.session && req.session.accessToken && req.session.userId===post._userId._id.toString()) { %>
            <a href="/posts/<%= post._id %>/edit" class="btn btn-sm btn-warning">Edit</a>
        <% } %>
    </div>

    <!-- Post -->
    <article class="mb-4 border-0 py-3">
        <header class="mb-3">
            <div class="d-flex justify-content-between align-items-start gap-3">
                <h1 class="mb-3 fw-normal">
                    <%= title %>
                </h1>

                <time datetime="<%= post.createdAt %>" class="text-muted small">
                    <%= new Date(post.createdAt).toLocaleString("fr-FR") %>
                </time>
            </div>

            <div class="text-muted small mt-1">
                Author : <span class="fw-semibold">
                    <%= post._userId?.username || "Unknown" %>
                </span>
                <% if (post.updatedAt && post.updatedAt !== post.createdAt) { %>
                    • Modified on
                    <time datetime="<%= post.updatedAt %>">
                        <%= new Date(post.updatedAt).toLocaleString("fr-FR") %>
                    </time>
                <% } %>
            </div>
        </header>

        <div class="fs-6 pt-3 border-top">
            <%- post.content %>
        </div>
    </article>

    <!-- Comments header -->
    <section aria-label="Comment" class="mb-3">
        <div class="d-flex justify-content-between align-items-center">
            <h2 class="h5 mb-0">Comments</h2>
            <span class="text-muted small">
                <%= (comments && comments.length) ? comments.length : 0 %> comment(s)
            </span>
        </div>
    </section>

    <%- include("./_form-comment", { post, fieldErrors, values }) %>

    <!-- Comments list -->
    <section>
        <% if (!comments || comments.length === 0) { %>

            <div class="alert alert-light border mb-4" role="status">
                No comments at this time.
            </div>

        <% } else { %>

            <ol class="list-unstyled">
                <% comments.forEach((comment)=> { %>
                    <li class="card mb-3">
                        <%- include("../partials/_card-comment", { comment }) %>
                    </li>
                <% }) %>
            </ol>

        <% } %>
    </section>
</main>

<%- include("../partials/_footer") %>