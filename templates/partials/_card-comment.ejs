<div class="card-body">

    <header class="d-flex justify-content-between align-items-start gap-3 mb-2">
        <div class="d-flex align-items-center gap-2">
            <div class="rounded-circle border d-inline-flex justify-content-center align-items-center"
                 style="width: 34px; height: 34px;">
                <span class="fw-semibold">
                    <%= (comment._userId?.username || "Unknown" ).toString().charAt(0).toUpperCase() %>
                </span>
            </div>

            <div>
                <div class="fw-semibold">
                    <%= comment._userId?.username || "Unknown" %>
                </div>
            </div>
        </div>

        <time datetime="<%= comment.createdAt %>" class="text-muted small">
            <%= comment.createdAt ? new Date(comment.createdAt).toLocaleString() : "" %>
        </time>
    </header>

    <div class="text-body">
        <p class="mb-0" style="white-space: pre-line;">
            <%= comment.message %>
        </p>
    </div>

    <% if (comment.updatedAt && comment.createdAt && comment.updatedAt !==comment.createdAt) { %>
        <div class="text-muted small mt-2">
            Modifié le
            <time datetime="<%= comment.updatedAt %>">
                <%= new Date(comment.updatedAt).toLocaleString() %>
            </time>
        </div>
    <% } %>

</div>